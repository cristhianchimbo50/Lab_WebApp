@page "/pacientes"
@inject SesionVerificacionService SesionService
@inject NavigationManager Nav

@rendermode InteractiveServer
<PageTitle>Gestión de Pacientes</PageTitle>

@using Lab_Blazor.Services.Auth
@using Lab_Blazor.Services.Pacientes
@using Lab_Contracts.Pacientes
@using Lab_Contracts.Common
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Security.Claims
@inject IPacientesApiService PacientesApiService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<AuthorizeView>
    <Authorized Context="authState">
        @{ 
            var user = authState.User; 
            var rol = user.FindFirst(ClaimTypes.Role)?.Value ?? user.FindFirst("IdRol")?.Value ?? ""; 
            bool puedeVer = rol is "1" or "2"; 
            bool puedeModificar = rol == "1"; 
        }

        @if (!puedeVer)
        {
            <div class="d-flex justify-content-center align-items-center vh-100">
                <div class="card shadow-lg text-center border-0" style="max-width: 450px;">
                    <div class="card-body p-4">
                        <i class="bi bi-shield-lock text-primary fs-1 mb-3"></i>
                        <h5 class="fw-bold mb-2">Acceso no autorizado</h5>
                        <p class="text-muted mb-3">No tienes permisos suficientes para acceder a este módulo.</p>
                        <button class="btn btn-outline-primary" @onclick="VolverAtrasAsync"><i class="bi bi-arrow-left"></i> Regresar</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <h3 class="mb-4 d-flex align-items-center text-uppercase justify-content-between fw-bold flex-wrap">
                <span><i class="bi bi-people text-primary fs-4 me-2"></i>Gestión de Pacientes</span>
                <button class="btn btn-success shadow-sm" @onclick="MostrarModalNuevoAsync"><i class="bi bi-person-plus-fill me-1"></i>Nuevo Paciente</button>
            </h3>

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-body row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Buscar por</label>
                        <InputSelect @bind-Value="_filtro.CriterioBusqueda" @bind-Value:after="AjustarValorBusquedaSegunCriterio" class="form-select">
                            <option value="">-- Seleccione --</option>
                            <option value="cedula">Cédula</option>
                            <option value="nombre">Nombre y Apellido</option>
                            <option value="correo">Correo</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Valor</label>
                        <input class="form-control @(_filtro.CriterioBusqueda == "nombre" ? "text-uppercase" : string.Empty)"
                               value="@ValorBusquedaFiltro"
                               placeholder="Ingrese valor a buscar"
                               @oninput="OnValorBusquedaInput"
                               @onkeypress="OnValorBusquedaKeyPressAsync" />
                    </div>
                    <div class="col-md-4 text-md-end text-center d-flex flex-wrap justify-content-md-end gap-2">
                        <button class="btn btn-primary" @onclick="OnBuscarClickAsync" disabled="@_buscando">
                            @if (_buscando){<span class="spinner-border spinner-border-sm me-1"></span>}
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarBusquedaAsync" disabled="@_buscando"><i class="bi bi-eraser me-1"></i>Limpiar</button>
                    </div>
                </div>
            </div>

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-body row g-3">
                    <div class="col-md-3 d-flex align-items-center mt-2">
                        <InputCheckbox @bind-Value="_filtro.IncluirAnulados" class="form-check-input me-2" />
                        <label class="form-check-label">Deshabilitado</label>
                    </div>
                    <div class="col-md-3 d-flex align-items-center mt-2">
                        <InputCheckbox @bind-Value="_filtro.IncluirVigentes" class="form-check-input me-2" />
                        <label class="form-check-label">Habilitado</label>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
                <div class="text-muted small">
                    @if (_resultado != null)
                    {
                        <span>@RangoMostrado</span>
                    }
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 small">Registros por página:</label>
                    <select class="form-select form-select-sm w-auto" @bind="_filtro.PageSize" @bind:after="async () => { _filtro.PageNumber = 1; await BuscarPacientesAsync(); }">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                    <div class="d-flex align-items-center ms-2">
                        <button class="btn btn-sm btn-outline-secondary me-1" disabled="@(_resultado == null || _resultado.PageNumber == 1)" @onclick="(() => CambiarPaginaAsync(-1))"><i class="bi bi-chevron-left"></i></button>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_resultado == null || _resultado.PageNumber >= TotalPaginas)" @onclick="(() => CambiarPaginaAsync(1))"><i class="bi bi-chevron-right"></i></button>
                    </div>
                </div>
            </div>

            @if (_resultado == null || _resultado.Items == null)
            {
                <div class="alert alert-info text-center shadow-sm"><i class="bi bi-info-circle me-2"></i>Presione <strong>Buscar</strong> para cargar los datos.</div>
            }
            else if (!_resultado.Items.Any())
            {
                <div class="alert alert-warning text-center shadow-sm"><i class="bi bi-exclamation-triangle me-2"></i>No se encontraron pacientes registrados.</div>
            }
            else
            {
                <div class="tabla-fija shadow-sm">
                    <div class="tabla-body">
                        <table class="table align-middle tabla-pacientes">
                            <thead>
                                <tr>
                                    <th style="width:10%; cursor:pointer;" @onclick="() => OrdenarPor(nameof(PacienteDto.Cedula))">Cédula @OrdenIcono(nameof(PacienteDto.Cedula))</th>
                                    <th style="width:15%; cursor:pointer;" @onclick="() => OrdenarPor(nameof(PacienteDto.Nombres))">Nombre @OrdenIcono(nameof(PacienteDto.Nombres))</th>
                                    <th style="width:7%; cursor:pointer;" @onclick="() => OrdenarPor(nameof(PacienteDto.FechaNacimiento))">Edad @OrdenIcono(nameof(PacienteDto.FechaNacimiento))</th>
                                    <th style="width:10%;">Género</th>
                                    <th style="width:15%">Dirección</th>
                                    <th style="width:15%; cursor:pointer;" @onclick="() => OrdenarPor(nameof(PacienteDto.Correo))">Correo @OrdenIcono(nameof(PacienteDto.Correo))</th>
                                    <th style="width:10%; cursor:pointer;" @onclick="() => OrdenarPor(nameof(PacienteDto.Telefono))">Teléfono @OrdenIcono(nameof(PacienteDto.Telefono))</th>
                                    <th style="width:8%">Estado</th>
                                    <th style="width:10%">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var paciente in _resultado.Items)
                                {
                                    <tr>
                                        <td data-label="Cédula">@paciente.Cedula</td>
                                        <td data-label="Nombre">@($"{paciente.Nombres} {paciente.Apellidos}")</td>
                                        <td data-label="Edad">@CalcularEdad(paciente.FechaNacimiento)</td>
                                        <td data-label="Género">@paciente.NombreGenero</td>
                                        <td data-label="Dirección">@paciente.Direccion</td>
                                        <td data-label="Correo">@paciente.Correo</td>
                                        <td data-label="Teléfono">@paciente.Telefono</td>
                                        <td data-label="Estado"><span class="badge bg-@(paciente.Activo ? "success" : "danger")">@(paciente.Activo ? "Habilitado" : "Deshabilitado")</span></td>
                                        <td data-label="Acciones">
                                            @if (puedeModificar)
                                            {
                                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarPacienteAsync(paciente)"><i class="bi bi-pencil-square"></i></button>
                                                @if (!paciente.Activo)
                                                {
                                                    <button class="btn btn-success btn-sm" @onclick="() => ConfirmarReactivacionAsync(paciente)"><i class="bi bi-check-circle-fill"></i></button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-danger btn-sm" @onclick="() => ConfirmarAnulacionAsync(paciente.IdPaciente)"><i class="bi bi-x-circle-fill"></i></button>
                                                }
                                            }
                                            else { <span class="text-muted small">Sin permisos</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="modal fade @(_modalVisible ? "show d-block" : "")" tabindex="-1" role="dialog" aria-modal="true" style="display:@(_modalVisible ? "block" : "none")">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content shadow-lg border-0">
                        <EditForm Model="@_pacienteActual" OnValidSubmit="ValidarYGuardarAsync" Context="editContext">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title"><i class="bi bi-person-circle me-2"></i>@(_pacienteActual.IdPaciente == 0 ? "Nuevo Paciente" : "Editar Paciente")</h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalAsync"></button>
                            </div>
                            <div class="modal-body">
                                <DataAnnotationsValidator />
                                <ValidationSummary />
                                <div class="row g-3">
                                    <div class="col-md-6"><label class="form-label">Cédula <span class="text-danger">*</span></label><InputText class="form-control" @bind-Value="_pacienteActual.Cedula" required @onblur="OnCedulaBlurAsync" disabled="@_camposPersonaBloqueados" /></div>
                                    <div class="col-md-6"><label class="form-label">Nombres <span class="text-danger">*</span></label><InputText class="form-control text-uppercase" @bind-Value="_pacienteActual.Nombres" required @oninput="(e => _pacienteActual.Nombres = e.Value?.ToString()?.ToUpper() ?? string.Empty)" disabled="@_camposPersonaBloqueados" /></div>
                                    <div class="col-md-6"><label class="form-label">Apellidos <span class="text-danger">*</span></label><InputText class="form-control text-uppercase" @bind-Value="_pacienteActual.Apellidos" required @oninput="(e => _pacienteActual.Apellidos = e.Value?.ToString()?.ToUpper() ?? string.Empty)" disabled="@_camposPersonaBloqueados" /></div>
                                    <div class="col-md-6"><label class="form-label">Fecha de Nacimiento</label><InputDate class="form-control" @bind-Value="_pacienteActual.FechaNacimiento" TValue="DateTime?" /></div>
                                    <div class="col-md-6"><label class="form-label">Teléfono</label><InputText class="form-control" @bind-Value="_pacienteActual.Telefono" disabled="@_camposPersonaBloqueados" /></div>
                                    <div class="col-md-6"><label class="form-label">Correo Electrónico</label><InputText class="form-control" @bind-Value="_pacienteActual.Correo" readonly="@(_pacienteActual.IdPaciente != 0 || _camposPersonaBloqueados)" disabled="@(_pacienteActual.IdPaciente != 0 || _camposPersonaBloqueados)" /></div>
                                    <div class="col-md-6"><label class="form-label">Dirección</label><InputText class="form-control" @bind-Value="_pacienteActual.Direccion" /></div>
                                    <div class="col-md-6">
                                        <label class="form-label">Género <span class="text-danger">*</span></label>
                                        <InputSelect class="form-select" @bind-Value="_pacienteActual.IdGenero">
                                            <option value="">Seleccione</option>
                                            @foreach (var g in _generos)
                                            {
                                                <option value="@g.IdGenero">@g.Nombre</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="mt-3 small text-danger">* Los datos en rojo son datos requeridos.</div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary px-3"><i class="bi bi-save me-1"></i>Guardar</button>
                                <button type="button" class="btn btn-secondary" @onclick="CerrarModalAsync"><i class="bi bi-x-lg me-1"></i>Cancelar</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private PacienteFiltroDto _filtro = new()
    {
        PageNumber = 1,
        PageSize = 10,
        SortBy = nameof(PacienteDto.Nombres),
        SortAsc = true,
        IncluirAnulados = true,
        IncluirVigentes = true
    };

    private ResultadoPaginadoDto<PacienteDto>? _resultado;

    private PacienteDto _pacienteActual = new();
    private bool _modalVisible;
    private bool _buscando = false;
    private bool _sesionVerificada = false;
    private bool _mostrarToastPorClickBuscar;
    private List<GeneroDto> _generos = new();
    private bool _datosAutocompletados;
    private bool _cedulaYaRegistradaComoPaciente;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_sesionVerificada)
        {
            _sesionVerificada = true;

            await SesionService.EjecutarConSesionAsync(async () =>
            {
                await CargarGenerosAsync();
            }, forzarVerificacion: true);
        }
    }

    private int TotalPaginas => _resultado == null || _resultado.PageSize == 0 ? 1 : (int)Math.Ceiling(_resultado.TotalCount / (double)_resultado.PageSize);

    private async Task CargarGenerosAsync()
    {
        try
        {
            _generos = await PacientesApiService.ListarGenerosAsync();
        }
        catch
        {
            await JS.InvokeVoidAsync("mostrarToastAsync", "No se pudieron cargar los géneros.", "warning");
        }
    }

    private Task BuscarPacientesAsync()
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (_buscando) return;
            try
            {
                _buscando = true;
                _resultado = await PacientesApiService.ListarPacientesPaginadosAsync(_filtro);
                if (_mostrarToastPorClickBuscar)
                {
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Pacientes cargados correctamente.", "success");
                }
            }
            catch
            {
                await JS.InvokeVoidAsync("mostrarToastAsync", "Error al buscar pacientes.", "danger");
            }
            finally
            {
                _buscando = false;
                _mostrarToastPorClickBuscar = false;
            }
        });

    private async Task OnBuscarClickAsync()
    {
        _mostrarToastPorClickBuscar = true;
        await BuscarPacientesAsync();
    }

    private string ValorBusquedaFiltro
    {
        get => _filtro.ValorBusqueda ?? string.Empty;
        set => _filtro.ValorBusqueda = _filtro.CriterioBusqueda == "nombre"
            ? (value ?? string.Empty).ToUpper()
            : value;
    }

    private void AjustarValorBusquedaSegunCriterio()
    {
        if (_filtro.CriterioBusqueda == "nombre")
        {
            _filtro.ValorBusqueda = (_filtro.ValorBusqueda ?? string.Empty).ToUpper();
        }
    }

    private void OnValorBusquedaInput(ChangeEventArgs e)
    {
        ValorBusquedaFiltro = e.Value?.ToString() ?? string.Empty;
    }

    private async Task OnValorBusquedaKeyPressAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await BuscarPacientesAsync();
        }
    }

    private async Task LimpiarBusquedaAsync()
    {
        _filtro = new PacienteFiltroDto { PageNumber = 1, PageSize = 10, SortBy = nameof(PacienteDto.Nombres), SortAsc = true, IncluirAnulados = true, IncluirVigentes = true };
        _resultado = null;
        await JS.InvokeVoidAsync("mostrarToastAsync", "Filtros restablecidos.", "secondary");
    }

    private async Task CambiarPaginaAsync(int delta)
    {
        if (_resultado == null) return;
        var nueva = Math.Max(1, Math.Min(TotalPaginas, _resultado.PageNumber + delta));
        if (nueva == _resultado.PageNumber) return;
        _filtro.PageNumber = nueva;
        await BuscarPacientesAsync();
    }

    private MarkupString OrdenIcono(string columna)
    {
        if (_filtro.SortBy != columna) return (MarkupString)string.Empty;
        var icon = _filtro.SortAsc ? "&uarr;" : "&darr;";
        return (MarkupString)$"<span class=\"ms-1\">{icon}</span>";
    }

    private void OrdenarPor(string columna)
    {
        if (_filtro.SortBy == columna)
            _filtro.SortAsc = !_filtro.SortAsc;
        else
        {
            _filtro.SortBy = columna;
            _filtro.SortAsc = true;
        }
        _filtro.PageNumber = 1;
        _ = BuscarPacientesAsync();
    }

    private async Task MostrarModalNuevoAsync()
    {
        _pacienteActual = new PacienteDto { FechaNacimiento = DateTime.Today.AddYears(-20), Activo = true };
        _datosAutocompletados = false;
        _cedulaYaRegistradaComoPaciente = false;
        _modalVisible = true;
        await JS.InvokeVoidAsync("marcarModalAbierto");
    }

    private async Task CerrarModalAsync()
    {
        _modalVisible = false;
        _cedulaYaRegistradaComoPaciente = false;
        await JS.InvokeVoidAsync("marcarModalCerrado");
    }

    private async Task EditarPacienteAsync(PacienteDto paciente)
    {
        if (!paciente.Activo)
        {
            await JS.InvokeVoidAsync("mostrarToastAsync", "Primero debe habilitar al paciente para poder modificarlo.", "warning");
            return;
        }

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var rol = authState.User.FindFirst(ClaimTypes.Role)?.Value ?? authState.User.FindFirst("IdRol")?.Value ?? "";
        if (rol != "1")
        {
            await JS.InvokeVoidAsync("alert", "No tienes permisos para editar pacientes.");
            return;
        }
        _pacienteActual = paciente;
        _datosAutocompletados = false;
        _modalVisible = true;
        await JS.InvokeVoidAsync("marcarModalAbierto");
    }

    private Task ValidarYGuardarAsync()
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            _pacienteActual.Telefono = string.IsNullOrWhiteSpace(_pacienteActual.Telefono) ? null : _pacienteActual.Telefono.Trim();
            _pacienteActual.Direccion = string.IsNullOrWhiteSpace(_pacienteActual.Direccion) ? null : _pacienteActual.Direccion.Trim();
            _pacienteActual.Correo = string.IsNullOrWhiteSpace(_pacienteActual.Correo) ? null : _pacienteActual.Correo.Trim();

            if (_pacienteActual.IdPaciente == 0)
            {
                if (_cedulaYaRegistradaComoPaciente)
                {
                    await JS.InvokeVoidAsync("alert", "La cédula ingresada ya está registrada como paciente. No se puede guardar.");
                    return;
                }

                var (exito, msg, _) = await PacientesApiService.GuardarPacienteAsync(_pacienteActual);
                await JS.InvokeVoidAsync("mostrarToastAsync", msg, exito ? "success" : "danger");
                if (exito)
                {
                    _modalVisible = false; await JS.InvokeVoidAsync("marcarModalCerrado"); await BuscarPacientesAsync();
                }
            }
            else
            {
                var resultadoOp = await PacientesApiService.GuardarPacienteAsync(_pacienteActual.IdPaciente, _pacienteActual);
                var mensaje = resultadoOp.IsSuccessStatusCode ? "Paciente actualizado correctamente." : "Error al actualizar paciente.";
                await JS.InvokeVoidAsync("mostrarToastAsync", mensaje, resultadoOp.IsSuccessStatusCode ? "success" : "danger");
                if (resultadoOp.IsSuccessStatusCode) { _modalVisible = false; await JS.InvokeVoidAsync("marcarModalCerrado"); await BuscarPacientesAsync(); }
            }
        });

    private bool _camposPersonaBloqueados => _datosAutocompletados;

    private async Task OnCedulaBlurAsync(FocusEventArgs _)
    {
        if (_pacienteActual.IdPaciente != 0) return;
        var cedula = _pacienteActual.Cedula?.Trim();
        if (string.IsNullOrWhiteSpace(cedula)) { _datosAutocompletados = false; return; }

        try
        {
            var existente = await PacientesApiService.ObtenerPacientePorCedulaAsync(cedula);
            if (existente != null)
            {
                _pacienteActual = existente;
                _datosAutocompletados = true;
                _cedulaYaRegistradaComoPaciente = true;
                await JS.InvokeVoidAsync("alert", "La cédula ingresada ya está registrada como paciente.");
            }
            else
            {
                var persona = await PacientesApiService.ObtenerPersonaPorCedulaAsync(cedula);
                if (persona != null)
                {
                    _pacienteActual.Cedula = persona.Cedula;
                    _pacienteActual.IdPersona = persona.IdPersona;
                    _pacienteActual.Nombres = persona.Nombres;
                    _pacienteActual.Apellidos = persona.Apellidos;
                    _pacienteActual.Correo = persona.Correo;
                    _pacienteActual.Telefono = persona.Telefono;
                    _pacienteActual.FechaNacimiento = persona.FechaNacimiento;
                    _pacienteActual.IdGenero = persona.IdGenero;
                    _datosAutocompletados = true;
                    _cedulaYaRegistradaComoPaciente = false;
                    var mensaje = string.IsNullOrWhiteSpace(persona.Correo)
                        ? "Persona encontrada. Se bloquearon los datos personales existentes."
                        : "Persona encontrada y ya tiene usuario registrado. Se bloquearon los datos personales existentes.";
                    await JS.InvokeVoidAsync("alert", mensaje);
                }
                else
                {
                    _datosAutocompletados = false;
                    _cedulaYaRegistradaComoPaciente = false;
                }
            }
        }
        catch
        {
            _datosAutocompletados = false;
            _cedulaYaRegistradaComoPaciente = false;
            await JS.InvokeVoidAsync("mostrarToastAsync", "No se pudo verificar la cédula.", "warning");
        }
    }

    private Task ConfirmarAnulacionAsync(int id)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (await JS.InvokeAsync<bool>("confirm", "¿Desea deshabilitar este paciente?"))
            {
                var resultadoOp = await PacientesApiService.AnularPacienteAsync(id);
                if (resultadoOp.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Paciente deshabilitado correctamente.", "success");
                    await BuscarPacientesAsync();
                }
            }
        });

    private Task ConfirmarReactivacionAsync(PacienteDto paciente)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (await JS.InvokeAsync<bool>("confirm", $"¿Desea reactivar al paciente {paciente.Nombres} {paciente.Apellidos}?"))
            {
                paciente.Activo = true;
                var resultadoOp = await PacientesApiService.GuardarPacienteAsync(paciente.IdPaciente, paciente);
                if (resultadoOp.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Paciente reactivado correctamente.", "success");
                    await BuscarPacientesAsync();
                }
            }
        });

    private async Task VolverAtrasAsync() => await JS.InvokeVoidAsync("history.back");

    private string RangoMostrado
    {
        get
        {
            if (_resultado == null || _resultado.TotalCount == 0) return "";
            int desde = ((_resultado.PageNumber - 1) * _resultado.PageSize) + 1;
            int hasta = Math.Min(_resultado.PageNumber * _resultado.PageSize, _resultado.TotalCount);
            return $"Mostrando {desde} - {hasta} de {_resultado.TotalCount} pacientes";
        }
    }

    private string CalcularEdad(DateTime? fechaNacimiento)
    {
        if (!fechaNacimiento.HasValue) return "-";
        var hoy = DateTime.Today;
        int edad = hoy.Year - fechaNacimiento.Value.Year;
        if (fechaNacimiento.Value > hoy.AddYears(-edad)) edad--;
        return edad.ToString();
    }
}
