@page "/examenes"
@rendermode InteractiveServer

<PageTitle>Gestión de Exámenes</PageTitle>

@using Lab_Contracts.Common
@using Lab_Contracts.Examenes
@using Lab_Blazor.Services.Examenes
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Lab_Blazor.Services.Auth
@inject SesionVerificacionService SesionService
@inject IExamenesApiService ExamenesApiService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@inject IExamenComposicionApiService ExamenComposicionApiService

<AuthorizeView>
    <Authorized Context="authState">
        @{
            var user = authState.User;
            var rol = user.FindFirst(ClaimTypes.Role)?.Value ?? user.FindFirst("IdRol")?.Value ?? string.Empty;
            bool puedeVer = rol is "1" or "3";
            bool puedeModificar = rol == "1";
        }

        @if (!puedeVer)
        {
            <div class="d-flex justify-content-center align-items-center vh-100">
                <div class="card shadow-lg text-center border-0" style="max-width: 450px;">
                    <div class="card-body p-4">
                        <i class="bi bi-shield-lock text-primary fs-1 mb-3"></i>
                        <h5 class="fw-bold mb-2">Acceso no autorizado</h5>
                        <p class="text-muted mb-3">No tienes permisos suficientes para acceder a este módulo.</p>
                        <button class="btn btn-outline-primary" @onclick="VolverAtrasAsync">
                            <i class="bi bi-arrow-left"></i> Regresar
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <h3 class="mb-4 d-flex align-items-center text-uppercase justify-content-between fw-bold flex-wrap">
                <span><i class="bi bi-clipboard2-pulse text-primary fs-4 me-2"></i>Gestión de Exámenes</span>
                <button class="btn btn-success shadow-sm" @onclick="MostrarModalNuevoAsync">
                    <i class="bi bi-plus-circle me-1"></i>Nuevo Examen
                </button>
            </h3>

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-body row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Buscar por</label>
                        <InputSelect @bind-Value="_filtro.CriterioBusqueda" class="form-select">
                            <option value="">-- Seleccione --</option>
                            <option value="nombre">Nombre</option>
                            <option value="estudio">Estudio</option>
                            <option value="tipo">Tipo de Examen</option>
                            <option value="tecnica">Técnica</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Valor</label>
                        <InputText class="form-control" @bind-Value="_filtro.ValorBusqueda" placeholder="Ingrese valor a buscar"
    @onkeypress="OnBuscarKeyPress" />
                    </div>

                    <div class="col-md-4 text-md-end text-center d-flex flex-wrap justify-content-md-end gap-2">
                        <button class="btn btn-primary" @onclick="() => BuscarExamenesAsync(true)" disabled="@_buscando">
                            @if (_buscando){<span class="spinner-border spinner-border-sm me-1"></span>}
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="LimpiarBusquedaAsync" disabled="@_buscando"><i class="bi bi-eraser me-1"></i>Limpiar</button>
                    </div>
                </div>
            </div>

            <div class="card mb-3 shadow-sm border-0">
                <div class="card-body row g-3">
                    <div class="col-md-3 d-flex align-items-center mt-2">
                        <InputCheckbox @bind-Value="_filtro.IncluirVigentes" class="form-check-input me-2" />
                        <label class="form-check-label">Habilitado</label>
                    </div>
                    <div class="col-md-3 d-flex align-items-center mt-2">
                        <InputCheckbox @bind-Value="_filtro.IncluirAnulados" class="form-check-input me-2" />
                        <label class="form-check-label">Inhabilitado</label>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                <div class="text-muted small">
                    @if (_resultado != null)
                    {
                        <span>@RangoMostrado</span>
                    }
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="form-label mb-0 small">Registros por página:</label>
                    <select class="form-select form-select-sm w-auto" @bind="_filtro.PageSize" @bind:after="async () => { _filtro.PageNumber = 1; await BuscarExamenesAsync(); }">
                        <option value="5">5</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                    <div class="d-flex align-items-center ms-2">
                        <button class="btn btn-sm btn-outline-secondary me-1" disabled="@(_resultado == null || _resultado.PageNumber == 1)" @onclick="(() => CambiarPaginaAsync(-1))"><i class="bi bi-chevron-left"></i></button>
                        <button class="btn btn-sm btn-outline-secondary" disabled="@(_resultado == null || _resultado.PageNumber >= TotalPaginas)" @onclick="(() => CambiarPaginaAsync(1))"><i class="bi bi-chevron-right"></i></button>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_mensaje))
            {
                <div class="alert alert-@_tipoMensaje alert-dismissible fade show" role="alert">
                    @_mensaje
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (_resultado == null)
            {
                <div class="alert alert-info text-center shadow-sm">
                    <i class="bi bi-info-circle me-2"></i>Presione <strong>Buscar</strong> para cargar los datos.
                </div>
            }
            else if (_resultado.TotalCount == 0)
            {
                <div class="alert alert-warning text-center shadow-sm">
                    <i class="bi bi-exclamation-triangle me-2"></i>No se encontraron resultados.
                </div>
            }
            else
            {



                <div class="tabla-fija shadow-sm rounded border">
                    <div class="tabla-body">
                        <table class="table align-middle mb-0 tabla-examenes">
                            <thead>
                                <tr>
                                    <th style="width: 18%;">Nombre</th>
                                    <th style="width: 15%;">Estudio</th>
                                    <th style="width: 14%;">Tipo de Muestra</th>
                                    <th style="width: 14%;">Tipo de Examen</th>
                                    <th style="width: 14%;">Técnica</th>
                                    <th style="width: 10%;">Precio</th>
                                    <th style="width: 7%;">Estado</th>
                                    <th style="width: 8%;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var examen in _resultado.Items)
                                {
                                    <tr>
                                         <td data-label="Nombre" class="text-truncate">@examen.NombreExamen</td>
                                        <td data-label="Estudio" class="text-truncate">@((examen.NombreEstudio ?? examen.Estudio) ?? string.Empty)</td>
                                        <td data-label="Tipo de Muestra" class="text-truncate">@((examen.NombreTipoMuestra ?? examen.TipoMuestra) ?? string.Empty)</td>
                                        <td data-label="Tipo de Examen" class="text-truncate">@((examen.NombreTipoExamen ?? examen.TipoExamen) ?? string.Empty)</td>
                                        <td data-label="Técnica" class="text-truncate">@((examen.NombreTecnica ?? examen.Tecnica) ?? string.Empty)</td>
                                        <td data-label="Precio" class="text-truncate">$@examen.Precio</td>
                                        <td data-label="Estado">
                                            <span class="badge bg-@(examen.Anulado ? "danger" : "success")">
                                                @(examen.Anulado ? "Inhabilitado" : "Habilitado")
                                            </span>
                                        </td>
                                        <td data-label="Acciones">
                                            @if (puedeModificar)
                                            {
                                                <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarExamenAsync(examen)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                @if (examen.Anulado)
                                                {
                                                    <button class="btn btn-success btn-sm" @onclick="() => ConfirmarReactivacionAsync(examen)">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-danger btn-sm" @onclick="() => ConfirmarAnulacionAsync(examen.IdExamen)">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Sin permisos</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="modal fade @(_modalVisible ? "show d-block" : "")" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-xl modal-dialog-centered">
                    <div class="modal-content shadow-lg border-0">

                        <EditForm Model="@_examenActual" OnValidSubmit="ValidarYGuardarAsync">
                            <div class="modal-header bg-primary text-white">
                                <h5 class="modal-title">
                                    <i class="bi bi-clipboard2-data me-2"></i>@(_examenActual.IdExamen == 0 ? "Nuevo Examen" : "Editar Examen")
                                </h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="CerrarModalAsync"></button>
                            </div>

                            <div class="modal-body">
                                <DataAnnotationsValidator />
                                <ValidationSummary />
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                                        <InputText class="form-control text-uppercase" @bind-Value="_examenActual.NombreExamen"
                                                   required
                                                   @oninput="(e => _examenActual.NombreExamen = e.Value?.ToString()?.ToUpper() ?? string.Empty)" />
                                    </div>
                                     <div class="col-md-6">
                                         <label class="form-label">Estudio</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdEstudio">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _estudiosCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>

                                     <div class="col-md-6">
                                         <label class="form-label">Grupo Examen</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdGrupoExamen">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _gruposCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>

                                     <div class="col-md-6">
                                         <label class="form-label">Tipo de Muestra</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdTipoMuestra">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _tiposMuestraCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>

                                     <div class="col-md-6">
                                         <label class="form-label">Tipo de Examen</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdTipoExamen">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _tiposExamenCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>

                                     <div class="col-md-6">
                                         <label class="form-label">Técnica</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdTecnica">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _tecnicasCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>
                                     <div class="col-md-6">
                                         <label class="form-label">Tipo de Registro</label>
                                         <InputSelect class="form-select" @bind-Value="_examenActual.IdTipoRegistro">
                                             <option value="">Seleccione</option>
                                             @foreach (var item in _tiposRegistroCatalogo)
                                             {
                                                 <option value="@item.Id">@item.Nombre</option>
                                             }
                                         </InputSelect>
                                     </div>
                                     <div class="col-md-6">
                                         <label class="form-label">Valor Referencia (Texto)</label>
                                         <InputText class="form-control" @bind-Value="_examenActual.ValorReferencia" />
                                     </div>
                                     <div class="col-md-3">
                                         <label class="form-label">Valor Mínimo</label>
                                         <InputNumber class="form-control" @bind-Value="_valorMinReferencia" TValue="decimal?" />
                                     </div>
                                     <div class="col-md-3">
                                         <label class="form-label">Valor Máximo</label>
                                         <InputNumber class="form-control" @bind-Value="_valorMaxReferencia" TValue="decimal?" />
                                     </div>
                                     <div class="col-md-4">
                                         <label class="form-label">Unidad</label>
                                         <InputText class="form-control text-uppercase" @bind-Value="_examenActual.Unidad" />
                                     </div>
                                     <div class="col-md-4">
                                         <label class="form-label">Precio <span class="text-danger">*</span></label>
                                         <InputNumber class="form-control" @bind-Value="_examenActual.Precio" required />
                                     </div>
                                     <div class="col-md-4">
                                         <label class="form-label">Tiempo de Entrega (minutos)</label>
                                         <InputNumber class="form-control" @bind-Value="_examenActual.TiempoEntregaMinutos" TValue="int?" />
                                     </div>
                                </div>

                                <div class="mt-2 small text-danger">* Los datos en rojo son datos requeridos.</div>

                                <hr class="my-3" />
                                <h5 class="fw-semibold"><i class="bi bi-diagram-3 me-1"></i> Exámenes Incluidos</h5>
                                <div class="mb-2 text-end">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AbrirModalBusquedaHijo">
                                        <i class="bi bi-plus-circle me-1"></i> Agregar Examen Incluido
                                    </button>
                                </div>

                                <div class="border rounded p-2" style="max-height: 250px; overflow-y: auto;">
                                    @if (_hijosSeleccionados.Count == 0)
                                    {
                                        <div class="text-muted text-center py-2">No se han agregado exámenes hijos.</div>
                                    }
                                    else
                                    {
                                        <table class="table table-sm table-hover align-middle text-center mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Nombre</th>
                                                    <th>Estudio</th>
                                                    <th style="width:50px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var hijo in _hijosSeleccionados)
                                                {
                                                    <tr>
                                                        <td>@hijo.NombreExamen</td>
                                                        <td>@((hijo.NombreEstudio ?? hijo.Estudio) ?? string.Empty)</td>
                                                        <td>
                                                            <button type="button" class="btn btn-danger btn-sm"
                                                                    @onclick="() => QuitarHijo(hijo.IdExamen)">
                                                                <i class="bi bi-x-circle"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </div>
                            </div>

                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary px-3">
                                    <i class="bi bi-save me-1"></i>Guardar
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="CerrarModalAsync">
                                    <i class="bi bi-x-lg me-1"></i>Cancelar
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>

            @if (_mostrarModalBusquedaHijo)
            {
                <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content shadow-lg">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-search me-1"></i> Buscar Examen Inlcuido</h5>
                                <button type="button" class="btn-close" @onclick="CerrarModalBusquedaHijo"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <InputSelect class="form-select" @bind-Value="_filtroBusquedaHijo">
                                            <option value="nombre">Nombre</option>
                                            <option value="estudio">Estudio</option>
                                        </InputSelect>
                                    </div>
                                    <div class="col-md-6">
                                        <InputText class="form-control" @bind-Value="_valorBusquedaHijo" placeholder="Ingrese valor" />
                                    </div>
                                    <div class="col-md-2 d-grid">
                                        <button class="btn btn-primary" @onclick="BuscarHijosAsync">
                                            <i class="bi bi-search"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="border rounded" style="max-height: 300px; overflow-y: auto;">
                                    <table class="table table-sm table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nombre</th>
                                                <th>Estudio</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var hijo in _resultadosBusquedaHijos)
                                            {
                                                <tr style="cursor:pointer" @ondblclick="() => SeleccionarHijoAsync(hijo)">
                                                    <td>@hijo.NombreExamen</td>
                                                    <td>@((hijo.NombreEstudio ?? hijo.Estudio) ?? string.Empty)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-secondary" @onclick="CerrarModalBusquedaHijo">Cerrar</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </Authorized>
</AuthorizeView>

@code {
    private ExamenFiltroDto _filtro = new()
    {
        PageNumber = 1,
        PageSize = 10,
        SortBy = nameof(ExamenDto.NombreExamen),
        SortAsc = true,
        IncluirAnulados = true,
        IncluirVigentes = true
    };

    private ResultadoPaginadoDto<ExamenDto>? _resultado;
    private bool _buscando = false;
    private ExamenDto _examenActual = new();
    private List<ExamenDto> _hijosSeleccionados = new();
    private bool _modalVisible = false;
    private string _mensaje = string.Empty;
    private string _tipoMensaje = "info";
    private bool _mostrarModalBusquedaHijo = false;
    private string _filtroBusquedaHijo = "nombre";
    private string _valorBusquedaHijo = string.Empty;
    private List<ExamenDto> _resultadosBusquedaHijos = new();
    private int _paginaActual = 1;
    private List<CatalogoExamenDto> _estudiosCatalogo = new();
    private List<CatalogoExamenDto> _gruposCatalogo = new();
    private List<CatalogoExamenDto> _tiposMuestraCatalogo = new();
    private List<CatalogoExamenDto> _tiposExamenCatalogo = new();
    private List<CatalogoExamenDto> _tecnicasCatalogo = new();
    private List<CatalogoExamenDto> _tiposRegistroCatalogo = new();
    private decimal? _valorMinReferencia;
    private decimal? _valorMaxReferencia;

    private async Task CargarCatalogosAsync()
    {
        _estudiosCatalogo = await ExamenesApiService.ListarCatalogoAsync("estudio", incluirInactivos: false);
        _gruposCatalogo = await ExamenesApiService.ListarCatalogoAsync("grupo_examen", incluirInactivos: false);
        _tiposMuestraCatalogo = await ExamenesApiService.ListarCatalogoAsync("tipo_muestra", incluirInactivos: false);
        _tiposExamenCatalogo = await ExamenesApiService.ListarCatalogoAsync("tipo_examen", incluirInactivos: false);
        _tecnicasCatalogo = await ExamenesApiService.ListarCatalogoAsync("tecnica", incluirInactivos: false);
        _tiposRegistroCatalogo = await ExamenesApiService.ListarCatalogoAsync("tipo_registro", incluirInactivos: false);
    }

    private Task BuscarExamenesAsync(bool mostrarToast = true)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (_buscando) return;
            try
            {
                _buscando = true;
                _resultado = await ExamenesApiService.ListarExamenesPaginadosAsync(_filtro);
                if (mostrarToast)
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Exámenes cargados correctamente.", "success");
            }
            catch
            {
                await JS.InvokeVoidAsync("mostrarToastAsync", "Error al buscar exámenes.", "danger");
            }
            finally { _buscando = false; }
        });

    private Task MostrarModalNuevoAsync()
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            _examenActual = new ExamenDto();
            _hijosSeleccionados = new();
            _valorMinReferencia = null;
            _valorMaxReferencia = null;
            await CargarCatalogosAsync();
            _modalVisible = true;
            await JS.InvokeVoidAsync("marcarModalAbierto");
        });

    private Task CerrarModalAsync()
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            _modalVisible = false;
            await JS.InvokeVoidAsync("marcarModalCerrado");
            _mensaje = string.Empty;
        });

    private Task EditarExamenAsync(ExamenDto examen)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var rol = authState.User.FindFirst(ClaimTypes.Role)?.Value ?? authState.User.FindFirst("IdRol")?.Value ?? string.Empty;
            if (rol != "1")
            {
                await JS.InvokeVoidAsync("mostrarToastAsync", "No tienes permisos para editar exámenes.", "danger");
                return;
            }

            _examenActual = examen;
            _hijosSeleccionados = await ExamenesApiService.ListarExamenesHijosAsync(examen.IdExamen) ?? new();
            var refActual = _examenActual.Referencias.FirstOrDefault();
            _valorMinReferencia = refActual?.ValorMin;
            _valorMaxReferencia = refActual?.ValorMax;
            await CargarCatalogosAsync();
            _modalVisible = true;
            await JS.InvokeVoidAsync("marcarModalAbierto");
        });

    private Task ValidarYGuardarAsync()
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (!string.IsNullOrWhiteSpace(_examenActual.ValorReferencia)
                || !string.IsNullOrWhiteSpace(_examenActual.Unidad)
                || _valorMinReferencia.HasValue
                || _valorMaxReferencia.HasValue)
            {
                _examenActual.Referencias = new List<ReferenciaExamenDto>
                {
                    new()
                    {
                        ValorMin = _valorMinReferencia,
                        ValorMax = _valorMaxReferencia,
                        ValorTexto = _examenActual.ValorReferencia,
                        Unidad = _examenActual.Unidad,
                        Activo = true
                    }
                };
            }

            HttpResponseMessage result;

            if (_examenActual.IdExamen == 0)
            {
                result = await ExamenesApiService.GuardarExamenAsync(_examenActual);
                if (result.IsSuccessStatusCode)
                {
                    var nuevo = await result.Content.ReadFromJsonAsync<ExamenDto>();
                    _examenActual.IdExamen = nuevo?.IdExamen ?? 0;
                }
            }
            else
            {
                result = await ExamenesApiService.GuardarExamenAsync(_examenActual.IdExamen, _examenActual);
            }

            if (result.IsSuccessStatusCode)
            {
                if (_hijosSeleccionados.Any())
                {
                    var hijosExistentes = await ExamenesApiService.ListarExamenesHijosAsync(_examenActual.IdExamen);
                    foreach (var hijo in hijosExistentes)
                    {
                        await ExamenComposicionApiService.EliminarComposicionAsync(_examenActual.IdExamen, hijo.IdExamen);
                    }

                    foreach (var hijo in _hijosSeleccionados)
                    {
                        await ExamenComposicionApiService.GuardarComposicionAsync(new ExamenComposicionDto
                        {
                            IdExamenPadre = _examenActual.IdExamen,
                            IdExamenHijo = hijo.IdExamen
                        });
                    }
                }
                _mensaje = "Examen y composiciones guardadas correctamente.";
                _tipoMensaje = "success";
                await JS.InvokeVoidAsync("mostrarToastAsync", _mensaje, _tipoMensaje);
                _modalVisible = false;
                await JS.InvokeVoidAsync("marcarModalCerrado");
                await BuscarExamenesAsync();
            }
            else
            {
                _mensaje = "Error al guardar examen.";
                _tipoMensaje = "danger";
                await JS.InvokeVoidAsync("mostrarToastAsync", _mensaje, _tipoMensaje);
            }
        });

    private Task ConfirmarAnulacionAsync(int id)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (await JS.InvokeAsync<bool>("confirm", "¿Desea anular este examen?"))
            {
                var result = await ExamenesApiService.AnularExamenAsync(id);
                if (result.IsSuccessStatusCode)
                {
                    _mensaje = "Examen anulado correctamente.";
                    _tipoMensaje = "success";
                    await BuscarExamenesAsync();
                }
            }
        });

    private async Task BuscarHijosAsync()
    {
        var todos = await ExamenesApiService.ListarExamenesAsync();
        var valorBusquedaHijo = _valorBusquedaHijo.ToLower();
        _resultadosBusquedaHijos = _filtroBusquedaHijo switch
        {
            "nombre" => todos.Where(e => e.NombreExamen.ToLower().Contains(valorBusquedaHijo)).ToList(),
            "estudio" => todos.Where(e => e.Estudio?.ToLower().Contains(valorBusquedaHijo) ?? false).ToList(),
            _ => new()
        };
    }

    private Task ConfirmarReactivacionAsync(ExamenDto examen)
        => SesionService.EjecutarConSesionAsync(async () =>
        {
            if (await JS.InvokeAsync<bool>("confirm", $"¿Desea reactivar el examen {examen.NombreExamen}?"))
            {
                examen.Anulado = false;
                var result = await ExamenesApiService.GuardarExamenAsync(examen.IdExamen, examen);
                if (result.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Examen reactivado correctamente.", "success");
                    await BuscarExamenesAsync();
                }
                else
                {
                    await JS.InvokeVoidAsync("mostrarToastAsync", "Error al reactivar el examen.", "danger");
                }
            }
        });

    private async void SeleccionarHijoAsync(ExamenDto examen)
    {
        if (_hijosSeleccionados.Any(x => x.IdExamen == examen.IdExamen))
        {
            await JS.InvokeVoidAsync("mostrarToastAsync", "Este examen ya está agregado como hijo.", "warning");
            return;
        }

        if (_examenActual.IdExamen == examen.IdExamen)
        {
            await JS.InvokeVoidAsync("mostrarToastAsync", "No puede agregarse a sí mismo como hijo.", "warning");
            return;
        }

        _hijosSeleccionados.Add(examen);
        _mostrarModalBusquedaHijo = false;
    }

    private void QuitarHijo(int id) =>
        _hijosSeleccionados = _hijosSeleccionados.Where(e => e.IdExamen != id).ToList();

    private void AbrirModalBusquedaHijo()
    {
        _valorBusquedaHijo = "";
        _resultadosBusquedaHijos = new();
        _mostrarModalBusquedaHijo = true;
    }

    private void CerrarModalBusquedaHijo() => _mostrarModalBusquedaHijo = false;

    private async Task LimpiarBusquedaAsync()
    {
        _filtro = new ExamenFiltroDto { PageNumber = 1, PageSize = 10, SortBy = nameof(ExamenDto.NombreExamen), SortAsc = true, IncluirAnulados = true, IncluirVigentes = true };
        _resultado = null;
        await JS.InvokeVoidAsync("mostrarToastAsync", "Filtros restablecidos.", "secondary");
    }

    private async Task CambiarPaginaAsync(int delta)
    {
        if (_resultado == null) return;
        var nueva = Math.Max(1, Math.Min(TotalPaginas, _resultado.PageNumber + delta));
        if (nueva == _resultado.PageNumber) return;
        _filtro.PageNumber = nueva;
        await BuscarExamenesAsync(false);
    }

    private string RangoMostrado
    {
        get
        {
            if (_resultado == null || _resultado.TotalCount == 0) return "";
            int desde = ((_resultado.PageNumber - 1) * _resultado.PageSize) + 1;
            int hasta = Math.Min(_resultado.PageNumber * _resultado.PageSize, _resultado.TotalCount);
            return $"Mostrando {desde} - {hasta} de {_resultado.TotalCount} exámenes";
        }
    }

    private int TotalPaginas => _resultado == null || _resultado.PageSize == 0 ? 1 : (int)Math.Ceiling(_resultado.TotalCount / (double)_resultado.PageSize);

    private void IrAPagina(int pagina) => _paginaActual = pagina;
    private void PrevPagina() { if (_paginaActual > 1) _paginaActual--; }
    private void NextPagina() { if (_paginaActual < TotalPaginas) _paginaActual++; }
    private void CambiarTamPagina() => _paginaActual = 1;
    private async Task VolverAtrasAsync() => await JS.InvokeVoidAsync("history.back");

    private async Task OnBuscarKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await BuscarExamenesAsync(false);
    }
}
